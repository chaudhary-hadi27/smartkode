generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  AGENCY
  CLIENT
  TECH
}

enum ClientType {
  LOCAL
  INTERNATIONAL
}

enum Currency {
  PKR
  USD
  EUR
  USDT
  USDC
  BTC
}

enum PaymentMethod {
  EASYPAISA
  JAZZCASH
  IBAN
  WISE
  PAYONEER
  NSAVE
  ELEVATE
  USDT
  USDC
  BTC
  TWOCHECKOUT
}

enum ProjectType {
  LARGE
  SMALL
}

enum ProjectStatus {
  INTAKE
  ASSIGNED
  IN_DEV
  QA
  DELIVERED
  APPROVED
  CLOSED
}

enum TechStatus {
  AVAILABLE
  BUSY
  ON_LEAVE
}

enum MilestoneStatus {
  PENDING
  INVOICED
  PAID
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum ScanStatus {
  PENDING
  CLEAN
  INFECTED
}

enum QAStatus {
  PENDING
  PASS
  FAIL
}

enum RetentionType {
  FOLLOWUP_48H
  FOLLOWUP_30D
  UPSELL
  TESTIMONIAL
  REACTIVATION
}

enum MessageChannel {
  EMAIL
  WHATSAPP
  BOTH
}

// ─── MODELS ─────────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String    @unique @db.VarChar(255)
  role               Role
  passkey_credential Json?     @db.JsonB
  password_hash      String?   @db.VarChar(255)
  is_active          Boolean   @default(true)
  last_login_at      DateTime? @db.Timestamp(6)
  created_at         DateTime  @default(now()) @db.Timestamp(6)
  updated_at         DateTime  @updatedAt @db.Timestamp(6)

  // Relations
  agency       Agency?
  client       Client?
  tech_company TechCompany?

  updated_settings ProfitSettings[] @relation("AdminSettingsUpdates")
  audit_logs       AuditLog[]       @relation("UserAuditLogs")
  uploaded_files   Deliverable[]    @relation("UserDeliverables")
  payments_made    Payment[]        @relation("UserPayments")

  @@map("users")
}

model ProfitSettings {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agency_default_percent Float    @default(10.0)
  tech_default_percent   Float    @default(40.0)
  admin_profit_percent   Float    @default(50.0) // Auto-calculated in code (100 - agency - tech)
  updated_by             String   @db.Uuid
  updated_at             DateTime @updatedAt @db.Timestamp(6)

  admin User @relation("AdminSettingsUpdates", fields: [updated_by], references: [id])

  @@map("profit_settings")
}

model Agency {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String   @unique @db.Uuid
  company_name       String   @db.VarChar(255)
  country            String?  @db.VarChar(100)
  phone              String?  @db.VarChar(100)
  commission_percent Float    // Copied from ProfitSettings at creation, but overrideable
  total_clients_sent Int      @default(0)
  total_earned       Float    @default(0.0)
  is_active          Boolean  @default(false)
  is_rejected        Boolean  @default(false)
  joined_at          DateTime @default(now()) @db.Timestamp(6)

  user     User      @relation(fields: [user_id], references: [id])
  projects Project[]
  clients  Client[] // First submission reference

  @@map("agencies")
}

model Client {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String        @unique @db.Uuid
  agency_id          String?       @db.Uuid // Nullable, as they might be direct later or admin added
  full_name          String        @db.VarChar(255)
  company_name       String?       @db.VarChar(255)
  whatsapp           String?       @db.VarChar(255) // Encrypted in DB
  email_contact      String?       @db.VarChar(255) // Encrypted in DB (differs from User.email for contact purposes)
  country            String?       @db.VarChar(100)
  client_type        ClientType    @default(INTERNATIONAL)
  preferred_currency Currency      @default(USD)
  preferred_payment  PaymentMethod @default(WISE)
  is_direct          Boolean       @default(false)
  lifetime_value     Float         @default(0.0)
  total_projects     Int           @default(0)
  created_at         DateTime      @default(now()) @db.Timestamp(6)

  user           User           @relation(fields: [user_id], references: [id])
  source_agency  Agency?        @relation(fields: [agency_id], references: [id])
  projects       Project[]
  retention_logs RetentionLog[]

  @@map("clients")
}

model TechCompany {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String     @unique @db.Uuid
  company_name        String     @db.VarChar(255)
  specialization      String?    @db.VarChar(255)
  tech_cut_percent    Float      // Copied from ProfitSettings
  availability_status TechStatus @default(AVAILABLE)
  total_projects_done Int        @default(0)
  total_paid          Float      @default(0.0)
  rating              Float      @default(0.0)
  joined_at           DateTime   @default(now()) @db.Timestamp(6)

  user     User      @relation(fields: [user_id], references: [id])
  projects Project[]

  @@map("tech_companies")
}

model Project {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agency_id           String?       @db.Uuid // Can be null if is_direct
  client_id           String        @db.Uuid
  tech_id             String?       @db.Uuid // Assigned by Admin
  title               String        @db.VarChar(500)
  description         String?       @db.Text
  type                ProjectType
  status              ProjectStatus @default(INTAKE)
  total_value         Float
  agency_cut          Float
  tech_cut            Float
  admin_profit        Float
  agency_percent_used Float
  tech_percent_used   Float
  p1_brief            String?       @db.Text
  client_approved     Boolean       @default(false)
  tech_rating         Int?
  deadline            DateTime?     @db.Timestamp(6)
  created_at          DateTime      @default(now()) @db.Timestamp(6)
  closed_at           DateTime?     @db.Timestamp(6)

  agency       Agency?        @relation(fields: [agency_id], references: [id])
  client       Client         @relation(fields: [client_id], references: [id])
  tech_company TechCompany?   @relation(fields: [tech_id], references: [id])
  milestones   Milestone[]
  invoices     Invoice[]
  deliverables Deliverable[]
  retentions   RetentionLog[]

  @@map("projects")
}

model OTPVerification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String   @unique @db.VarChar(255)
  code       String   @db.VarChar(10)
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)

  @@map("otp_verifications")
}

model Milestone {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id   String          @db.Uuid
  title        String          @db.VarChar(255)
  order_index  Int
  percent_due  Float
  amount_due   Float
  status       MilestoneStatus @default(PENDING)
  due_date     DateTime?       @db.Timestamp(6)
  invoice_id   String?         @unique @db.Uuid
  completed_at DateTime?       @db.Timestamp(6)

  project Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoice_id], references: [id], onDelete: SetNull)

  @@map("milestones")
}

model Invoice {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id           String        @db.Uuid
  invoice_number       String        @unique @db.VarChar(100)
  amount               Float
  agency_share         Float
  tech_share           Float
  admin_share          Float
  currency             Currency
  converted_amount_pkr Float?
  pdf_url              String?       @db.VarChar(1000)
  status               InvoiceStatus @default(DRAFT)
  payment_method       PaymentMethod
  sent_at              DateTime?     @db.Timestamp(6)
  paid_at              DateTime?     @db.Timestamp(6)

  project   Project    @relation(fields: [project_id], references: [id], onDelete: Cascade)
  milestone Milestone?
  payment   Payment?

  @@map("invoices")
}

model Payment {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id         String        @unique @db.Uuid
  payer_id           String        @db.Uuid
  method             PaymentMethod
  currency_paid      Currency
  amount_paid        Float
  amount_pkr_equiv   Float?
  iban_number        String?       @db.VarChar(255) // Encrypted
  mobile_number      String?       @db.VarChar(255) // Encrypted
  crypto_wallet      String?       @db.VarChar(255)
  transaction_ref    String?       @db.VarChar(255)
  status             PaymentStatus @default(PENDING)
  confirmed_at       DateTime?     @db.Timestamp(6)

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  payer   User    @relation("UserPayments", fields: [payer_id], references: [id])

  @@map("payments")
}

model Deliverable {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id        String     @db.Uuid
  uploaded_by       String     @db.Uuid
  file_name         String     @db.VarChar(500)
  file_url          String     @db.VarChar(1000)
  file_size_mb      Float?
  github_url        String?    @db.VarChar(1000)
  virus_scan_status ScanStatus @default(PENDING)
  virus_scan_result Json?      @db.JsonB
  bot_qa_status     QAStatus   @default(PENDING)
  bot_qa_notes      String?    @db.Text
  visible_to_client Boolean    @default(false)
  uploaded_at       DateTime   @default(now()) @db.Timestamp(6)

  project  Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  uploader User    @relation("UserDeliverables", fields: [uploaded_by], references: [id])

  @@map("deliverables")
}

model RetentionLog {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id            String         @db.Uuid
  project_id           String         @db.Uuid
  type                 RetentionType
  message_sent         String?        @db.Text
  channel              MessageChannel
  scheduled_at         DateTime       @db.Timestamp(6)
  sent_at              DateTime?      @db.Timestamp(6)
  opened               Boolean        @default(false)
  response_received    Boolean        @default(false)
  response_text        String?        @db.Text
  converted_to_project Boolean        @default(false)

  client  Client  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("retention_logs")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  action      String   @db.VarChar(255)
  entity_type String   @db.VarChar(255)
  entity_id   String   @db.Uuid
  old_value   Json?    @db.JsonB
  new_value   Json?    @db.JsonB
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now()) @db.Timestamp(6)

  user User @relation("UserAuditLogs", fields: [user_id], references: [id])

  @@map("audit_logs")
}
